#!/bin/sh
# benchy installer — https://benchy.run
# Usage: curl -fsSL https://benchy.run/install | sh
set -eu

BASE_URL="https://benchy.run/dl"
INSTALL_DIR="${BENCHY_INSTALL_DIR:-${BENCH_INSTALL_DIR:-$HOME/.local/bin}}"

main() {
  os=$(uname -s | tr '[:upper:]' '[:lower:]')
  arch=$(uname -m)
  case "$arch" in
    x86_64|amd64) arch="amd64" ;;
    arm64|aarch64) arch="arm64" ;;
    *) err "unsupported architecture: $arch" ;;
  esac
  case "$os" in
    darwin|linux) ;;
    *) err "unsupported OS: $os (darwin and linux only)" ;;
  esac

  url="$BASE_URL/benchy-$os-$arch"
  echo "Downloading benchy ($os/$arch)..."
  mkdir -p "$INSTALL_DIR"
  tmp=$(mktemp)
  curl -fsSL "$url" -o "$tmp" || err "download failed: $url"
  chmod +x "$tmp"
  mv "$tmp" "$INSTALL_DIR/benchy"
  # compat: keep `bench` working for anyone with the old name in muscle memory
  ln -sf "$INSTALL_DIR/benchy" "$INSTALL_DIR/bench"
  echo "Installed benchy to $INSTALL_DIR/benchy"

  case ":$PATH:" in
    *":$INSTALL_DIR:"*) ;;
    *) echo "NOTE: $INSTALL_DIR is not on your PATH — add it to your shell profile." ;;
  esac

  echo "Setting up the agent skill and config..."
  "$INSTALL_DIR/benchy" install

  echo ""
  echo "Done! Next steps:"
  echo "  benchy setup     # check agent logins, pick a judge"
  echo "  /add-to-benchy   # capture an eval inside your coding agent"
  echo "  benchy run       # replay evals and score the leaderboard"
}

err() { echo "error: $1" >&2; exit 1; }

main
